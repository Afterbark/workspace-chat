# Copy to .env and fill in real values:  cp .env.example .env
# Never commit .env (it's gitignored).

# --- infra (used by docker-compose) ---
DOMAIN=chat.yourname.me              # the domain pointed at the droplet; Caddy gets a cert for it
POSTGRES_PASSWORD=change-me-to-a-strong-password

# --- app core ---
SECRET_KEY=change-me-to-a-long-random-string   # e.g. `python -c "import secrets;print(secrets.token_hex(32))"`
# DATABASE_URL is injected by docker-compose (points at the db service) — leave it unset here.

# --- Cloudinary (file/image storage) ---
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# --- Web push (VAPID) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_EMAIL=mailto:you@example.com

# --- integrations ---
GIPHY_API_KEY=
ADMIN_USERNAMES=Larry

# --- optional ---
SENTRY_DSN=
