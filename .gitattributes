# These files run on the Linux droplet — force LF line endings so they don't
# break with Windows-style carriage returns.
*.sh         text eol=lf
deploy.sh    text eol=lf
Dockerfile   text eol=lf
Caddyfile    text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
.dockerignore text eol=lf
.env.example text eol=lf
